{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Notra Documentation",
  "description": "Documentation for Notra, the content pipeline for teams.",
  "colors": {
    "primary": "#8b5cf6",
    "light": "#8b5cf6",
    "dark": "#8b5cf6"
  },
  "background": {
    "decoration": "windows"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/",
      "destination": "/overview"
    },
    {
      "source": "/api",
      "destination": "/api/getting-started"
    },
    {
      "source": "/sdk/getting-started",
      "destination": "/api/getting-started"
    }
  ],
  "api": {
    "url": "full"
  },
  "metadata": {
    "timestamp": true
  },
  "seo": {
    "metatags": {
      "twitter:site": "@usenotra"
    }
  },
  "search": {
    "prompt": "Search the Notra docs..."
  },
  "errors": {
    "404": {
      "redirect": false,
      "title": "This page is on a content pipeline of its own",
      "description": "Looks like this page hasn't shipped yet. Try the [quickstart](/quickstart) or head back to the [overview](/overview)."
    }
  },
  "contextual": {
    "options": ["copy", "assistant", "mcp", "chatgpt", "claude", "perplexity"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["overview", "quickstart"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/how-it-works",
              "concepts/content-pipeline",
              "concepts/brand-voice"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/github",
              "integrations/linear",
              "integrations/slack",
              "integrations/framer",
              "integrations/featul",
              "integrations/kontentspace"
            ]
          },
          {
            "group": "Developer Tools",
            "pages": ["devtools/cli", "devtools/mcp", "devtools/raycast"]
          },
          {
            "group": "Automation",
            "pages": [
              "automation/overview",
              "automation/event-based",
              "automation/scheduled"
            ]
          },
          {
            "group": "Content Types",
            "pages": [
              "content/changelogs",
              "content/blog-posts",
              "content/social-media"
            ]
          },
          {
            "group": "Organization",
            "pages": [
              "organization/workspace-setup",
              "organization/team-management",
              "organization/billing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "api/getting-started",
              "api/authentication",
              "api/rate-limits"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "api/rust-sdk",
              "api/caching",
              "api/common-tasks",
              "api/pagination",
              "api/types"
            ]
          },
          {
            "group": "Webhooks",
            "pages": ["api/webhooks/overview", "api/webhooks/events"]
          },
          {
            "group": "Endpoints",
            "expanded": true,
            "openapi": {
              "source": "https://api.usenotra.com/openapi.json",
              "directory": "api-reference"
            },
            "pages": [
              {
                "group": "Posts",
                "expanded": true,
                "pages": [
                  "GET /v1/posts",
                  "GET /v1/posts/{postId}",
                  "PATCH /v1/posts/{postId}",
                  "DELETE /v1/posts/{postId}",
                  {
                    "group": "Generation",
                    "expanded": true,
                    "pages": [
                      "POST /v1/posts/generate",
                      "GET /v1/posts/generate/{jobId}"
                    ]
                  }
                ]
              },
              {
                "group": "Brand Identities",
                "expanded": true,
                "pages": [
                  "GET /v1/brand-identities",
                  "GET /v1/brand-identities/{brandIdentityId}",
                  "PATCH /v1/brand-identities/{brandIdentityId}",
                  "DELETE /v1/brand-identities/{brandIdentityId}",
                  {
                    "group": "Generation",
                    "expanded": true,
                    "pages": [
                      "POST /v1/brand-identities/generate",
                      "GET /v1/brand-identities/generate/{jobId}"
                    ]
                  }
                ]
              },
              {
                "group": "Integrations",
                "expanded": true,
                "pages": [
                  "GET /v1/integrations",
                  "POST /v1/integrations/github",
                  "DELETE /v1/integrations/{integrationId}"
                ]
              },
              {
                "group": "Schedules",
                "expanded": true,
                "pages": [
                  "GET /v1/schedules",
                  "POST /v1/schedules",
                  "PATCH /v1/schedules/{scheduleId}",
                  "DELETE /v1/schedules/{scheduleId}"
                ]
              },
              {
                "group": "Skills",
                "expanded": true,
                "pages": [
                  "GET /v1/skills",
                  "POST /v1/skills",
                  "GET /v1/skills/{name}",
                  "PATCH /v1/skills/{name}",
                  "DELETE /v1/skills/{name}"
                ]
              },
              {
                "group": "Chats",
                "expanded": true,
                "pages": [
                  "GET /v1/chats",
                  "POST /v1/chats",
                  "GET /v1/chats/{chatId}",
                  "POST /v1/chats/{chatId}"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Discord Community",
          "href": "https://www.usenotra.com/discord",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "favicon.svg",
    "dark": "favicon.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/usenotra/notra"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/usenotra",
      "github": "https://github.com/usenotra"
    }
  }
}
