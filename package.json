{
  "name": "turbo",
  "private": true,
  "scripts": {
    "build": "dotenv -- turbo run build",
    "dev": "dotenv -- turbo run dev",
    "check-types": "dotenv -- turbo run check-types",
    "knip": "dotenv -- turbo run knip --filter=web --filter=dashboard --filter=api",
    "db:generate": "dotenv -- bunx drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:migrate": "dotenv -- bunx drizzle-kit migrate --config packages/db/drizzle.config.ts",
    "db:push": "dotenv -- bunx drizzle-kit push --config packages/db/drizzle.config.ts",
    "db:studio": "dotenv -- bunx drizzle-kit studio --config packages/db/drizzle.config.ts",
    "db:drop": "dotenv -- bunx drizzle-kit drop --config packages/db/drizzle.config.ts",
    "db:pull": "dotenv -- bunx drizzle-kit pull --config packages/db/drizzle.config.ts",
    "email:dev": "dotenv -- bun run --filter=@notra/email dev",
    "check": "ultracite check",
    "format": "ultracite fix",
    "format:unsafe": "ultracite fix --unsafe",
    "commitlint": "commitlint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "husky": "^9.1.7",
    "knip": "^6.12.2",
    "openlogs": "^0.0.1",
    "turbo": "^2.9.14",
    "ultracite": "7.1.4"
  },
  "engines": {
    "node": "24.11.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.9"
}
